NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
NEXT_PUBLIC_SITE_URL=https://nodeguard.example.gov.ph
# Server-only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional provider-neutral SMS webhook. NodeGuard sends a JSON POST with
# { to, recipient, incidentId, message } after a responder assignment.
SMS_WEBHOOK_URL=https://your-sms-provider.example/send
SMS_WEBHOOK_TOKEN=your-optional-webhook-bearer-token
# Local UI verification only. Never enable this in an operational deployment.
NEXT_PUBLIC_NODEGUARD_DEMO_MODE=false
